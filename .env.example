# Copy to .env and fill in. Never commit .env.
DATABASE_URL=postgresql://rag:rag@localhost:5433/rag
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Embeddings (OpenAI). 1536 dims for text-embedding-3-small.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Generation provider: "anthropic" (default) or "openai"
GEN_PROVIDER=anthropic
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_MODEL=gpt-4o-mini

# Retrieval tuning
CHUNK_TOKENS=512
CHUNK_OVERLAP=64
CANDIDATE_K=30
TOP_K=8
RRF_K=60
